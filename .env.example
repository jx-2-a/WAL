# DeepSeek API Key
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-api-key-here

# 可选：覆盖 API 地址
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Python 虚拟环境路径（默认值如下，可按需修改）
WAL_VENV=d:\PyVenv\WAL

# 联网搜索后端（web_search / web_fetch）
#   bing        — 默认，cn.bing.com 国内直连，无需 VPN
#   duckduckgo  — DuckDuckGo Lite，海外环境可用
#   auto        — Bing 优先，失败自动降级到 DuckDuckGo
# SEARCH_BACKEND=bing

# 可选：自定义项目目录
# WAL_PROJECTS=./projects
